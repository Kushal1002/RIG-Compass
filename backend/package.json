{
  "name": "rig-engagement-tracker-backend",
  "version": "1.0.0",
  "description": "CAP backend for RIG Engagement Tracker",
  "dependencies": {
    "@sap/cds": "^9",
    "cds-swagger-ui-express": "^0.11.0",
    "express": "^4",
    "uuid": "^14.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      }
    },
    "server": {
      "cors": true
    }
  }
}
